includes:
	- phpstan-baseline.neon

parameters:
		parallel:
				maximumNumberOfProcesses: 5

		level: 7

		bootstrapFiles:
				- vendor/autoload.php

		paths:
				- Classes
				- Configuration
				- Tests

		ignoreErrors:
				- '#return type has no value type specified in iterable type array#'
				- '#with no value type specified in iterable type array#'
